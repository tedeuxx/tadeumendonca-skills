{
  "extraKnownMarketplaces": {
    "tadeumendonca": {
      "source": { "source": "github", "repo": "tedeuxx/tadeumendonca-skills" }
    }
  },
  "enabledPlugins": {
    "tadeumendonca-skills@tadeumendonca": true
  },
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue create:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(npx bump-my-version:*)",
      "Bash(bump-my-version:*)"
    ],
    "deny": [
      "Bash(git push:*--tags*)",
      "Bash(git push:*--follow-tags*)",
      "Bash(gh workflow run release*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)",
      "Bash(*--force*)",
      "Bash(*--hard*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
